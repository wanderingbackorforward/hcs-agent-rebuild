# ==========================================
# 模型提供商配置
# ==========================================
# 可选值: openai, qwen, deepseek, zhipu, azure, openai-compatible
MODEL_PROVIDER=qwen

# --- 通用 LLM 配置 ---
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# --- Embedding 配置 ---
# Provider 可选值: minimax, qwen, deepseek, zhipu, azure, openai, openai-compatible, local
# - minimax / qwen / openai 等: 云端 API，填 EMBEDDING_API_KEY + EMBEDDING_BASE_URL
# - local: 内网私有化部署，通过 sentence-transformers 本地推理，无需 API Key
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v3
# local provider 专用: 推理设备 (cpu / cuda)
# EMBEDDING_DEVICE=cpu

# --- local provider 示例（内网私有化部署 BGE 模型）---
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# EMBEDDING_DEVICE=cpu
# 其他可选模型: BAAI/bge-m3 (带代码匹配效果更好)

# --- Azure OpenAI 专用配置 ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_VERSION=2024-02-01
AZURE_OPENAI_ENDPOINT_EMBEDDING=
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=
AZURE_OPENAI_EMBEDDING_VERSION=2023-05-15

# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL=sqlite:///./data/hcs_agent.db
# SQL 回显(调试用)
DB_ECHO=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ==========================================
# 应用配置
# ==========================================
APP_NAME=HCS 测试辅助 Agent 平台
APP_DESCRIPTION=HCS 测试环境匹配 + MCP 知识检索 Agent 平台
APP_VERSION=0.1.0
DEBUG=True
LOG_LEVEL=INFO

# --- 服务器 ---
HOST=127.0.0.1
PORT=8000

# --- CORS ---
# 逗号分隔的来源白名单，* 表示允许全部
CORS_ORIGINS=*
# 注意: CORS_ORIGINS=* 时 credentials 自动关闭(CORS 规范要求)
CORS_ALLOW_CREDENTIALS=False

# --- 目录 ---
STATIC_DIR=web/static
TEMPLATES_DIR=web/templates
PROMPTS_DIR=prompts

# --- 会话缓存(防止内存泄漏) ---
# 每个进程最多缓存的会话数(LRU 淘汰)
SESSION_CACHE_MAX_SIZE=100
# 会话过期时间(秒)
SESSION_CACHE_TTL=3600

# ==========================================
# API 访问控制(生产必填)
# ==========================================
# 逗号分隔的 API Key 列表。空 = dev 模式(无认证,仅本地用)
# API_KEYS=key1,key2,key3
# 速率限制:每 key 每窗口秒最多 RATE_LIMIT_MAX 次
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=10

# ==========================================
# Redis 配置(可选)
# ==========================================
# 留空则使用进程内限流/缓存，填入后启用 Redis 分布式限流和缓存
# REDIS_URL=redis://localhost:6379/0

# ==========================================
# 向量库配置
# ==========================================
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_DISTANCE=cosine
KNOWLEDGE_COLLECTION=hcs_knowledge

# ==========================================
# 检索配置
# ==========================================
# 默认检索数量
RETRIEVAL_TOP_K=5
# 记忆检索数量
MEMORY_TOP_K=3

# ==========================================
# LLM 调用参数
# ==========================================
# 默认 temperature(0=确定性输出)
LLM_TEMPERATURE=0.0
# tiktoken 分词器模型名(仅用于 token 计数，不影响实际调用模型)
TIKTOKEN_MODEL=gpt-4

# ==========================================
# 上下文管理
# ==========================================
CONTEXT_MAX_TOKENS=6000
CONTEXT_SYSTEM_BUDGET=500
CONTEXT_RESPONSE_BUDGET=1000

# ==========================================
# 记忆系统
# ==========================================
# 短期记忆
STM_MAX_TURNS=6
STM_KEEP_RECENT=4
# 长期记忆
LTM_IMPORTANCE_THRESHOLD=0.7
LTM_CONFIDENCE_THRESHOLD=0.15
LTM_RECENCY_HALFLIFE=604800
LTM_TTL=2592000
# 上下文锁
CONTEXT_LOCK_TTL=600

# ==========================================
# ReAct 循环
# ==========================================
REACT_MAX_ITERATIONS=5

# ==========================================
# 缓存 TTL(秒)
# ==========================================
LLM_CACHE_TTL=1800
TOOL_CACHE_TTL=600
SEMANTIC_CACHE_TTL=900
SEMANTIC_CACHE_THRESHOLD=0.92

# ==========================================
# 阈值
# ==========================================
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.5
SEMANTIC_SIMILARITY_THRESHOLD=0.65

# ==========================================
# 代码审查
# ==========================================
CODE_REVIEW_CHUNK_SIZE=3000
CODE_REVIEW_CHUNK_OVERLAP=200

# ==========================================
# 探测服务
# ==========================================
PROBE_TIMEOUT=2

# ==========================================
# MCP 服务器
# ==========================================
MCP_TRANSPORT=stdio
MCP_SERVER_NAME=hcs-agent-rebuild
MCP_SSE_HOST=0.0.0.0
MCP_SSE_PORT=8080

# ==========================================
# RAG 工厂参数
# ==========================================
# 分块器
CHUNKER_SIZE=600
CHUNKER_OVERLAP=100
CHUNKER_LANG=python
# 分块质量守卫(rule-based pre-filter,默认关闭)
# 开启后:规则前置筛选,仅可疑 chunk 才走 embedding 语义再切,降低大文档入库成本
CHUNK_GUARD_ENABLED=False
# 触发"结构稀疏"检查的最小字符数(短于此不检查)
CHUNK_GUARD_MIN_CHARS=300
# 合格 chunk 至少含有的分隔符数(换行/句号等),低于此值且超长则可疑
CHUNK_GUARD_MIN_SEPARATORS=2
# 语义再切时相邻句子的相似度阈值,低于此值在该处切分
CHUNK_GUARD_RESPLIT_THRESHOLD=0.45
# 重排序模型
CROSS_ENCODER_MODEL=
