# ==========================================
# 模型提供商配置
# ==========================================
# 可选值: openai, qwen, deepseek, zhipu, azure, openai-compatible
MODEL_PROVIDER=qwen

# --- 通用 LLM 配置 ---
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# --- Embedding 配置 ---
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v3

# --- Azure OpenAI 专用配置 ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_VERSION=2024-02-01

# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL=sqlite:///./data/hcs_agent.db

# ==========================================
# 应用配置
# ==========================================
DEBUG=True
LOG_LEVEL=INFO

# ==========================================
# API 访问控制(生产必填)
# ==========================================
# 逗号分隔的 API Key 列表。空 = dev 模式(无认证,仅本地用)
# API_KEYS=key1,key2,key3
# 速率限制:每 key 每窗口秒最多 RATE_LIMIT_MAX 次
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=10
