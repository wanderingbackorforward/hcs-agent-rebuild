# ==========================================
# 模型提供商配置
# ==========================================
# 可选值: openai, qwen, deepseek, zhipu, azure, openai-compatible
MODEL_PROVIDER=qwen

# --- 通用 LLM 配置 ---
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# --- Embedding 配置 ---
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v3

# --- Azure OpenAI 专用配置 ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_VERSION=2024-02-01

# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL=sqlite:///./data/hcs_agent.db

# ==========================================
# 应用配置
# ==========================================
DEBUG=True
LOG_LEVEL=INFO
